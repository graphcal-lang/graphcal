{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Graphcal",
  "scopeName": "source.graphcal",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#attribute" },
    { "include": "#fn-declaration" },
    { "include": "#type-declaration" },
    { "include": "#dimension-declaration" },
    { "include": "#unit-declaration" },
    { "include": "#index-declaration" },
    { "include": "#param-declaration" },
    { "include": "#node-declaration" },
    { "include": "#const-declaration" },
    { "include": "#assert-declaration" },
    { "include": "#import-declaration" },
    { "include": "#let-binding" },
    { "include": "#for-binding" },
    { "include": "#as-keyword" },
    { "include": "#control-keywords" },
    { "include": "#scan-keyword" },
    { "include": "#generic-params" },
    { "include": "#return-type" },
    { "include": "#type-annotation" },
    { "include": "#qualified-fn-call" },
    { "include": "#fn-call" },
    { "include": "#graph-ref" },
    { "include": "#qualified-const-ref" },
    { "include": "#qualified-variant" },
    { "include": "#booleans" },
    { "include": "#wildcard" },
    { "include": "#numbers" },
    { "include": "#builtin-types" },
    { "include": "#upper-constant" },
    { "include": "#pascal-type" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.graphcal",
      "match": "//.*$"
    },

    "strings": {
      "name": "string.quoted.double.graphcal",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.graphcal" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.graphcal" }
      }
    },

    "fn-declaration": {
      "match": "\\b(fn)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.fn.graphcal" },
        "2": { "name": "entity.name.function.graphcal" }
      }
    },

    "type-declaration": {
      "match": "\\b(type)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.graphcal" },
        "2": { "name": "entity.name.type.graphcal" }
      }
    },

    "dimension-declaration": {
      "match": "\\b(dimension)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.dimension.graphcal" },
        "2": { "name": "entity.name.type.graphcal" }
      }
    },

    "unit-declaration": {
      "match": "\\b(unit)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.unit.graphcal" },
        "2": { "name": "entity.name.type.graphcal" }
      }
    },

    "index-declaration": {
      "match": "\\b(index)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.index.graphcal" },
        "2": { "name": "entity.name.type.graphcal" }
      }
    },

    "param-declaration": {
      "match": "\\b(param)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.param.graphcal" },
        "2": { "name": "variable.other.graphcal" }
      }
    },

    "node-declaration": {
      "match": "\\b(node)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.node.graphcal" },
        "2": { "name": "variable.other.graphcal" }
      }
    },

    "const-declaration": {
      "match": "\\b(const)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.const.graphcal" },
        "2": { "name": "variable.other.constant.graphcal" }
      }
    },

    "attribute": {
      "comment": "Attribute: #[name] or #[name(arg1, arg2, Index::Variant, (A::X, B::Y))]",
      "begin": "(#)(\\[)",
      "end": "(\\])",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.attribute.graphcal" },
        "2": { "name": "punctuation.definition.attribute.graphcal" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.attribute.graphcal" }
      },
      "patterns": [
        {
          "match": "\\b([a-zA-Z][a-zA-Z0-9_]*)\\b",
          "name": "entity.other.attribute-name.graphcal"
        },
        {
          "match": "::",
          "name": "punctuation.separator.namespace.graphcal"
        },
        {
          "match": "[(),]",
          "name": "punctuation.separator.graphcal"
        }
      ]
    },

    "assert-declaration": {
      "match": "\\b(assert)\\s+([a-z][a-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.assert.graphcal" },
        "2": { "name": "variable.other.graphcal" }
      }
    },

    "import-declaration": {
      "begin": "\\b(import)\\b",
      "end": ";",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.import.graphcal" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.terminator.graphcal" }
      },
      "patterns": [
        { "include": "#strings" },
        {
          "comment": "Module alias: import '...' as alias",
          "match": "\\b(as)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.operator.as.graphcal" },
            "2": { "name": "entity.name.namespace.graphcal" }
          }
        },
        { "include": "#import-param-bindings" },
        { "include": "#import-item-list" }
      ]
    },

    "import-param-bindings": {
      "comment": "Param bindings for module instantiation: (name = expr, ...)",
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": { "name": "punctuation.brackets.round.graphcal" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.brackets.round.graphcal" }
      },
      "patterns": [
        {
          "comment": "Param binding: name = expr",
          "match": "\\b([a-zA-Z][a-zA-Z0-9_]*)\\s*(=)",
          "captures": {
            "1": { "name": "variable.other.graphcal" },
            "2": { "name": "keyword.operator.assignment.graphcal" }
          }
        },
        { "include": "#graph-ref" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#strings" },
        { "include": "#qualified-fn-call" },
        { "include": "#fn-call" },
        { "include": "#qualified-const-ref" },
        { "include": "#upper-constant" },
        { "include": "#pascal-type" },
        { "include": "#operators" },
        {
          "match": ",",
          "name": "punctuation.separator.comma.graphcal"
        }
      ]
    },

    "import-item-list": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.brackets.curly.graphcal" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.brackets.curly.graphcal" }
      },
      "patterns": [
        {
          "match": "\\b(as)\\b",
          "name": "keyword.operator.as.graphcal"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.graphcal"
        },
        {
          "comment": "ALL_CAPS identifiers are constants",
          "match": "\\b([A-Z][A-Z0-9_]*[A-Z0-9])\\b|\\b([A-Z]{2,})\\b",
          "name": "variable.other.constant.graphcal"
        },
        {
          "comment": "PascalCase identifiers are types/dimensions/indexes",
          "match": "\\b([A-Z][a-z][a-zA-Z0-9_]*)\\b",
          "name": "entity.name.type.graphcal"
        },
        {
          "comment": "snake_case identifiers are variables (params, nodes, fns)",
          "match": "\\b([a-zA-Z][a-zA-Z0-9_]*)\\b",
          "name": "variable.other.graphcal"
        }
      ]
    },

    "as-keyword": {
      "match": "\\b(as)\\b",
      "name": "keyword.operator.as.graphcal"
    },

    "let-binding": {
      "match": "\\b(let)\\s+([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.let.graphcal" },
        "2": { "name": "variable.other.graphcal" }
      }
    },

    "for-binding": {
      "comment": "for m: Maneuver, n: Phase — highlight all bindings in the for-header",
      "begin": "\\b(for)\\b",
      "end": "(?=\\{)",
      "beginCaptures": {
        "1": { "name": "keyword.control.graphcal" }
      },
      "patterns": [
        {
          "match": "\\b([a-zA-Z][a-zA-Z0-9_]*)\\s*(:)\\s*([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.graphcal" },
            "2": { "name": "punctuation.separator.colon.graphcal" },
            "3": { "name": "entity.name.type.graphcal" }
          }
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.graphcal"
        },
        {
          "match": "=>",
          "name": "keyword.operator.fat-arrow.graphcal"
        }
      ]
    },

    "control-keywords": {
      "match": "\\b(if|else|for|match|table)\\b",
      "name": "keyword.control.graphcal"
    },

    "scan-keyword": {
      "match": "\\b(scan)\\s*(?=\\()",
      "captures": {
        "1": { "name": "support.function.graphcal" }
      }
    },

    "generic-params": {
      "comment": "Generic parameters: <D: Dim>, <D: Dim, I: Index>",
      "begin": "<(?=[A-Z]\\w*\\s*:)",
      "end": ">",
      "beginCaptures": {
        "0": { "name": "punctuation.brackets.angle.graphcal" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.brackets.angle.graphcal" }
      },
      "patterns": [
        { "include": "#builtin-types" },
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "entity.name.type.graphcal" },
            "2": { "name": "punctuation.separator.colon.graphcal" }
          }
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.graphcal"
        }
      ]
    },

    "return-type": {
      "comment": "Return type after ') ->': -> D, -> Velocity, -> TransferResult",
      "begin": "(?<=\\))\\s*(->)\\s*(?=[A-Za-z])",
      "end": "(?=[=;{])",
      "beginCaptures": {
        "1": { "name": "keyword.operator.arrow.graphcal" }
      },
      "patterns": [
        { "include": "#builtin-types" },
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
          "name": "entity.name.type.graphcal"
        },
        {
          "match": "[\\[\\]]",
          "name": "punctuation.brackets.square.graphcal"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.graphcal"
        }
      ]
    },

    "fn-call": {
      "comment": "Function calls: sqrt(...), orbital_velocity(...), max(...), etc.",
      "match": "\\b([a-zA-Z][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.graphcal" }
      }
    },

    "type-annotation": {
      "comment": "Type annotation after ':' — matches ': Type', ': Type[Index, ...]', ': Dimensionless[...]'",
      "begin": "(?<=\\w)\\s*(:)\\s*(?=[A-Z])",
      "end": "(?=[=;,){])",
      "beginCaptures": {
        "1": { "name": "punctuation.separator.colon.graphcal" }
      },
      "patterns": [
        { "include": "#builtin-types" },
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
          "name": "entity.name.type.graphcal"
        },
        {
          "match": "[\\[\\]]",
          "name": "punctuation.brackets.square.graphcal"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.graphcal"
        },
        {
          "match": "[*/^]",
          "name": "keyword.operator.arithmetic.graphcal"
        },
        { "include": "#numbers" }
      ]
    },

    "graph-ref": {
      "comment": "Graph references: @name or @module::name",
      "match": "(@)(?:([a-z][a-z0-9_]*)(::))?([a-zA-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.definition.variable.graphcal" },
        "2": { "name": "entity.name.namespace.graphcal" },
        "3": { "name": "punctuation.separator.namespace.graphcal" },
        "4": { "name": "variable.other.graphcal" }
      }
    },

    "qualified-fn-call": {
      "comment": "Qualified function call: module::fn_name(...)",
      "match": "\\b([a-z][a-z0-9_]*)(::)([a-z][a-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.namespace.graphcal" },
        "2": { "name": "punctuation.separator.namespace.graphcal" },
        "3": { "name": "entity.name.function.graphcal" }
      }
    },

    "qualified-const-ref": {
      "comment": "Qualified const reference: module::CONST_NAME",
      "match": "\\b([a-z][a-z0-9_]*)(::)([A-Z][A-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "entity.name.namespace.graphcal" },
        "2": { "name": "punctuation.separator.namespace.graphcal" },
        "3": { "name": "variable.other.constant.graphcal" }
      }
    },

    "qualified-variant": {
      "match": "\\b([A-Z][a-zA-Z0-9_]*)(::)([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "entity.name.type.graphcal" },
        "2": { "name": "punctuation.separator.namespace.graphcal" },
        "3": { "name": "variable.other.enummember.graphcal" }
      }
    },

    "booleans": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.graphcal"
    },

    "wildcard": {
      "match": "(?<![a-zA-Z0-9])_(?![a-zA-Z0-9_])",
      "name": "variable.language.wildcard.graphcal"
    },

    "numbers": {
      "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9]+)?\\b",
      "name": "constant.numeric.graphcal"
    },

    "builtin-types": {
      "match": "\\b(Dimensionless|Bool|Int|Datetime|Dim|Index)\\b",
      "name": "support.type.graphcal"
    },

    "upper-constant": {
      "comment": "ALL_CAPS identifiers are constants (PI, G0, TWO_G0, R_EARTH, GM_EARTH, etc.)",
      "match": "\\b([A-Z][A-Z0-9_]*[A-Z0-9])\\b|\\b([A-Z]{2,})\\b",
      "name": "variable.other.constant.graphcal"
    },

    "pascal-type": {
      "comment": "PascalCase identifiers are types/dimensions (Velocity, Length, Time, Mass, etc.)",
      "match": "\\b([A-Z][a-z][a-zA-Z0-9_]*)\\b",
      "name": "entity.name.type.graphcal"
    },

    "operators": {
      "patterns": [
        {
          "match": "=>",
          "name": "keyword.operator.fat-arrow.graphcal"
        },
        {
          "match": "->",
          "name": "keyword.operator.arrow.graphcal"
        },
        {
          "match": "~=",
          "name": "keyword.operator.tolerance.graphcal"
        },
        {
          "match": "\\+/-",
          "name": "keyword.operator.plus-minus.graphcal"
        },
        {
          "match": "::",
          "name": "punctuation.separator.namespace.graphcal"
        },
        {
          "match": "==|!=|<=|>=|<|>",
          "name": "keyword.operator.comparison.graphcal"
        },
        {
          "match": "&&|\\|\\|",
          "name": "keyword.operator.logical.graphcal"
        },
        {
          "match": "[+\\-*/^%]",
          "name": "keyword.operator.arithmetic.graphcal"
        },
        {
          "match": "!",
          "name": "keyword.operator.logical.not.graphcal"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.graphcal"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "match": "[()]",
          "name": "punctuation.brackets.round.graphcal"
        },
        {
          "match": "[\\[\\]]",
          "name": "punctuation.brackets.square.graphcal"
        },
        {
          "match": "[{}]",
          "name": "punctuation.brackets.curly.graphcal"
        },
        {
          "match": ";",
          "name": "punctuation.terminator.graphcal"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.graphcal"
        },
        {
          "match": ":",
          "name": "punctuation.separator.colon.graphcal"
        },
        {
          "match": "\\.",
          "name": "punctuation.accessor.dot.graphcal"
        },
        {
          "match": "\\|",
          "name": "punctuation.separator.pipe.graphcal"
        }
      ]
    }
  }
}
