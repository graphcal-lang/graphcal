// domain_scalar.gcl -- scalar params with domain constraints
dimension Velocity = Length / Time;
dimension Force = Mass * Length / Time^2;

// Two-sided constraint
param bus_mass: Mass = 500.0 kg;

// One-sided (min only)
param thrust: Force = 0.5 N;

// One-sided (max only)
param efficiency: Dimensionless = 0.85;

// Int constraint
param count: Int = 10;

node double_thrust: Force = @thrust * 2.0;
