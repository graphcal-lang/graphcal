// main.gcl -- overrides Phase but forgets to re-bind cost → V005.
//
// Under A8, overriding `Phase` orphans `cost`'s default because it
// mentions `Phase.Design` / `Phase.Build` — variants that do not
// exist in the replacement index `MyPhase`.
index MyPhase = { Plan, Make };

#[allow_defaults]
include lib(Phase: MyPhase { }).{ total };

node result: Dimensionless = @total;
