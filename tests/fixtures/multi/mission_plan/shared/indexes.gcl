// shared/indexes.gcl -- Mission phase and subsystem indexes
cat MissionPhase {
    Launch,
    LeoParking,
    TransLunarInjection,
    TransLunarCoast,
    LunarOrbitInsertion,
    LunarOps,
    TransEarthInjection,
    TransEarthCoast,
    EarthReturn,
}

cat Subsystem {
    Propulsion,
    AttitudeControl,
    CommandAndData,
    Telecom,
    Thermal,
    Power,
    Structure,
    Payload,
}
