// Test datetime extraction functions
param t: Datetime = datetime("2024-11-05T14:30:45Z");

node y: Int = year(@t);
node mo: Int = month(@t);
node d: Int = day(@t);
node h: Int = hour(@t);
node mi: Int = minute(@t);
node s: Int = second(@t);
node wd: Int = weekday(@t);
node doy: Int = day_of_year(@t);

assert year_check = @y == 2024;
assert month_check = @mo == 11;
assert day_check = @d == 5;
assert hour_check = @h == 14;
assert minute_check = @mi == 30;
assert second_check = @s == 45;
// 2024-11-05 is a Tuesday (weekday index 1)
assert weekday_check = @wd == 1;
// Nov 5 is the 310th day of 2024 (leap year)
assert day_of_year_check = @doy == 310;
