// plot_line.gcl -- Line chart with range index
//
// Demonstrates a line chart using a range index for time-series data,
// showing exponential decay over discrete time steps.

dimension Frequency = Time^-1;

index TimeStep = range(0.0 s, 2.0 s, step: 0.5 s);

param decay_rate: Frequency = 1.0 Hz;
param initial_value: Dimensionless = 10.0;

node y: Dimensionless[TimeStep] = unfold(@initial_value, |prev_t, t| {
    let dt = t - prev_t;
    @y[prev_t] * (1.0 - @decay_rate * dt)
});

plot decay_curve = {
    mark: line,
    encode: {
        x: for t: TimeStep { t },
        y: for t: TimeStep { @y[t] },
    },
    title: "Exponential Decay",
    x_label: "Time",
    y_label: "Value",
};
