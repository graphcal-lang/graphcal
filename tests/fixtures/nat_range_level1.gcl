// nat_range_level1.gcl -- Nat arithmetic Level 1 (addition)
// --- N + 1 in type position: drop_last ---
// Takes a vector of size N + 1, returns a vector of size N.
// The solver deduces N from the argument: N + 1 = 4 => N = 3
fn drop_last<N: Nat, D: Dim>(v: D[N + 1]) -> D[N] = for i: range(N) { v[i] };

param v4: Dimensionless[4] = for i: range(4) { 1.0 };
node v3: Dimensionless[3] = drop_last(@v4);

// --- N + 1 with dimension-carrying types ---
fn drop_last_dim<N: Nat, D: Dim>(v: D[N + 1]) -> D[N] = for i: range(N) { v[i] };

param w5: Length[5] = for i: range(5) { 1.0 m };
node w4: Length[4] = drop_last_dim(@w5);

// --- N + K for K > 1 ---
fn drop_last2<N: Nat, D: Dim>(v: D[N + 2]) -> D[N] = for i: range(N) { v[i] };

param v6: Dimensionless[6] = for i: range(6) { 2.0 };
node v4b: Dimensionless[4] = drop_last2(@v6);

// --- Composition with named indexes ---
index Phase = { Launch, Cruise, Arrival };

fn drop_last_rows<N: Nat, D: Dim>(m: D[N + 1, Phase]) -> D[N, Phase] = for i: range(N), p: Phase {
    m[i, p]
};

param mat: Dimensionless[4, Phase] = for i: range(4), p: Phase { 1.0 };
node mat_trimmed: Dimensionless[3, Phase] = drop_last_rows(@mat);

// --- range(N + K) in for-comprehension body ---
// Creates a larger output with range(N + 1) in the for binding.
fn pad_zero<N: Nat>(v: Dimensionless[N]) -> Dimensionless[N + 1] = for i: range(N + 1) {
    if i < N { v[i] } else { 0.0 }
};

param short: Dimensionless[3] = for i: range(3) { 5.0 };
node padded: Dimensionless[4] = pad_zero(@short);

// --- Identity matrix ---
// eye takes a template vector to carry N until turbofish syntax is supported (#322).
fn eye<N: Nat>(template: Dimensionless[N]) -> Dimensionless[N, N] =
    for i: range(N), j: range(N) { if i == j { 1.0 } else { 0.0 } };

param ones3: Dimensionless[3] = for i: range(3) { 1.0 };
node eye3: Dimensionless[3, 3] = eye(@ones3);

// --- Matrix multiplication ---
fn matmul<M: Nat, N: Nat, P: Nat, D1: Dim, D2: Dim>(
    a: D1[M, N], b: D2[N, P]
) -> (D1 * D2)[M, P] = for i: range(M), k: range(P) {
    sum(for j: range(N) { a[i, j] * b[j, k] })
};

param mat_a: Dimensionless[2, 3] = for i: range(2), j: range(3) { 1.0 };
param mat_b: Dimensionless[3, 2] = for i: range(3), j: range(2) { 1.0 };
node mat_ab: Dimensionless[2, 2] = matmul(@mat_a, @mat_b);

// --- Trace ---
fn trace<N: Nat, D: Dim>(a: D[N, N]) -> D =
    sum(for i: range(N) { a[i, i] });

node trace_eye3: Dimensionless = trace(@eye3);
