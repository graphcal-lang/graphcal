// nat_range.gcl -- Nat sort and range(N) index constructor (Level 0)

// --- Basic nat range types ---

// A 3-element vector indexed by range(3)
param v: Dimensionless[3] = for i: range(3) { 1.0 };

// A 2x3 matrix indexed by range(2) x range(3)
param m: Dimensionless[2, 3] = for i: range(2), j: range(3) { 1.0 };

// --- Indexing with nat range loop variables ---

// Element-wise operations on nat-indexed types
node v_doubled: Dimensionless[3] = for i: range(3) { @v[i] * 2.0 };

// --- Generic function with Nat params: transpose ---

fn transpose<M: Nat, N: Nat, D: Dim>(a: D[M, N]) -> D[N, M] =
    for j: range(N), i: range(M) { a[i, j] };

param mat23: Dimensionless[2, 3] = for i: range(2), j: range(3) { 1.0 };

node mat32: Dimensionless[3, 2] = transpose(@mat23);

// --- Generic dot product ---

fn dot<N: Nat, D1: Dim, D2: Dim>(a: D1[N], b: D2[N]) -> D1 * D2 =
    sum(for i: range(N) { a[i] * b[i] });

param a3: Length[3] = for i: range(3) { 1.0 m };
param b3: Dimensionless[3] = for i: range(3) { 2.0 };

node dot_result: Length = dot(@a3, @b3);
