// figure_hidden.gcl -- Non-pub plots with figure
//
// Plots without `pub` are hidden from standalone output.
// Only the figure's combined chart should appear in the output.
pub index Step = { First, Second, Third, Fourth };

param x0: Dimensionless = 1.0;

param values: Dimensionless[Step] = {
    Step.First: 1.0,
    Step.Second: 2.0,
    Step.Third: 4.0,
    Step.Fourth: 8.0,
};

plot curve_a = {
    mark: line,
    encode: {
        x: for s: Step { @values[s] },
        y: for s: Step { @values[s] * @values[s] },
    },
    title: "Values Squared",
};

plot curve_b = {
    mark: bar,
    encode: {
        x: for s: Step { @values[s] },
        y: for s: Step { @values[s] + 1.0 },
    },
    title: "Values Plus One",
};

figure comparison = {
    plots: [curve_a, curve_b],
    title: "Combined View",
};
