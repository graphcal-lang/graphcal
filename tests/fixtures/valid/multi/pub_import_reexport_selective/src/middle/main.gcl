// main.gcl -- imports `Acceleration` (a pub dim) transitively via middle.gcl.
//
// `middle.gcl` re-exports `Acceleration` via `{ pub Acceleration }`,
// so `Acceleration` appears in `middle.gcl`'s visible surface and this
// import succeeds. Issue #452.
import middle.lib.{ Acceleration };

const node result: Acceleration = 9.80665 m/s^2;
