// main.gcl -- imports `GravityAccel` (a pub dim) transitively via middle.gcl.
//
// `middle.gcl` re-exports `GravityAccel` via `{ pub GravityAccel }`,
// so `GravityAccel` appears in `middle.gcl`'s visible surface and this
// import succeeds. Issue #452.
import middle.lib.{ GravityAccel };

const node result: GravityAccel = 9.80665 m/s^2;
