// Two modules may define the same unit name differently: each import alias
// scopes its own `mile`, so the references stay unambiguous (no merge
// conflict is possible for module imports).
import app.units_a as ua;
import app.units_b as ub;

param a: Length = 3218.688 m;
node b: Length = @a -> ua.mile;
node c: Length = @a -> ub.mile;
