// Issue #577: a unit literal whose terms repeat a base unit (e.g., `m/s/s`)
// must render in canonical normalized form so the displayed label parses
// back to the same dimensional monomial. Before the fix, `1.0 m/s/s` would
// print as `1 m/s * s`, which is mathematically `m`.

pub dim Foo = Length / Time / Time;

param chained: Foo = 1.0 m/s/s;
param explicit: Foo = 2.0 m/s^2;
