// convert_one_over.gcl -- `1/unit` reciprocal shorthand (#648 U2/N4).
// The canonical display label for min^-1 is `1/min`; the parser accepts the
// same form so displayed units round-trip as source.
param f: Frequency = 2.0 Hz;
node per_minute: Frequency = @f -> 1/min;
node per_minute_pow: Frequency = @f -> min^-1;
unit per_min: Frequency = (1.0 / 60.0) 1/s;
node via_decl: Frequency = @f -> per_min;
assert same = @per_minute == @per_minute_pow;
