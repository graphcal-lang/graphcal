// tagged_union.gcl -- Tagged union types and match expressions (issue #601 syntax)
pub dim Velocity = Length / Time;
pub dim Force = Mass * Length / Time^2;

// Multi-variant tagged union.
pub type ManeuverKind {
    Impulsive(delta_v: Velocity),
    LowThrust(thrust: Force, duration: Time),
}

// Record-shaped types are single-variant tagged unions whose sole
// constructor's name matches the type's name (record sugar pending).
pub type TransferResult {
    TransferResult(dv1: Velocity, dv2: Velocity),
}

param thrust_level: Force = 0.5 N;
param burn_duration: Time = 3600.0 s;

// Construct a variant via the parens constructor-call form.
node maneuver: ManeuverKind = LowThrust(thrust: @thrust_level, duration: @burn_duration);

// Match on the union — pattern bindings are still brace-style.
node fuel_proxy: Force = match @maneuver {
    Impulsive { delta_v: _ } => 0.0 N,
    LowThrust { thrust, duration: _ } => thrust,
};

// Construct the single-variant union with the same parens form.
node transfer: TransferResult = TransferResult(dv1: 100.0 m/s, dv2: 200.0 m/s);

// Field access on a single-variant union works as if it were a record.
node total_dv: Velocity = @transfer.dv1 + @transfer.dv2;

// Mixed union: unit + payload-bearing constructors.
pub type Status {
    Nominal,
    Warning(code: Dimensionless),
}

node current_status: Status = Nominal;

node status_code: Dimensionless = match @current_status {
    Nominal => 0.0,
    Warning { code } => code,
};
