// plot_heatmap.gcl -- Heatmap with 2D indexed data
//
// Demonstrates a rect mark chart visualizing power draw across
// subsystems and operating modes as a 2D grid: the 2D `color`
// comprehension drives a Subsystem × OpMode row per cell, and the 1D
// `x`/`y` channels broadcast across the axis they do not mention.
pub index Subsystem = { Comms, Thermal, Payload };
pub index OpMode = { Safe, Nominal, Science };

param power_draw: Power[Subsystem, OpMode] = table[Subsystem, OpMode] {
           :  Safe, Nominal, Science;
    Comms:   2.0 W,   5.0 W,   3.0 W;
    Thermal: 8.0 W,   5.0 W,   5.0 W;
    Payload: 0.0 W,   0.0 W,  35.0 W;
};

plot power_heatmap = {
    mark: rect,
    encode: {
        x: for m: OpMode { m },
        y: for s: Subsystem { s },
        color: for s: Subsystem, m: OpMode { @power_draw[s, m] },
    },
    title: "Power Draw Heatmap",
    x_label: "Operating Mode",
    y_label: "Subsystem",
};
