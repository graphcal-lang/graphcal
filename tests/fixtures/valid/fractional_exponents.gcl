// fractional_exponents.gcl -- rational exponents in dimension and unit
// expressions (#648 U3). `^(p/q)` parses everywhere `^n` does; the TIR
// always carried rational exponents — only the surface grammar blocked them.
pub dim RootLen = Length^(1/2);

param a: Length = 4.0 m;
node r: RootLen = sqrt(@a);
node disp: RootLen = @r -> m^(1/2);

const unit rootcm: RootLen = 0.1 m^(1/2);
node disp2: RootLen = @r -> rootcm;

node back: Length = @r * @r;
assert roundtrip = @back == @a;
