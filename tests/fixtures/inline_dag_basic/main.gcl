// Basic inline DAG test: define a DAG and include it.
pub dim Velocity = Length / Time;

dag double_speed {
    param v: Velocity;

    node result: Velocity = @v * 2.0;
}

param speed: Velocity = 10.0 m/s;
include double_speed(v: @speed) { result as doubled };
node final_result: Velocity = @doubled;
