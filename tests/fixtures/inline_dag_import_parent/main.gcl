// Inline DAG with import .. for parent scope access.
dim Velocity = Length / Time;
dim GravParam = Length^3 / Time^2;

const node gm: GravParam = 3.986004418e14 m^3/s^2;
const node r_earth: Length = 6371000.0 m;

dag circular_velocity {
    import main.{gm, r_earth};
    
    param alt: Length;
    
    node v: Velocity = sqrt(@gm / (@r_earth + @alt));
}

param altitude: Length = 400000.0 m;
include circular_velocity(alt: @altitude).{ v as orbital_v };
node result: Velocity = @orbital_v;
