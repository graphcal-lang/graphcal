// main.gcl -- cross-file assumes test
include "./checks.gcl" { limit };
import "./checks.gcl" { limit_positive };

param value: Dimensionless = 42.0;

#[assumes(limit_positive)]
node ratio: Dimensionless = @value / @limit;
