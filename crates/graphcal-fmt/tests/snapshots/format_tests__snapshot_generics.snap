// generics.gcl -- Generic structs with phantom type parameters
pub dim Velocity = Length / Time;

// Marker types for reference frames
pub type Eci {}
pub type Body {}

// Generic struct with dim param and phantom type param
pub type Vec3<D: Dim, F: Type> {
    x: D,
    y: D,
    z: D,
}

// Construction with explicit type args
param pos_eci: Vec3<Length, Eci> = Vec3<Length, Eci> { x: 6878.0 km, y: 0.0 km, z: 0.0 km};

param vel_eci: Vec3<Velocity, Eci> = Vec3<Velocity, Eci> { x: 0.0 m/s, y: 7.67 km/s, z: 0.0 m/s};

// Field access on generic struct
node x_pos: Length = @pos_eci.x;
node y_vel: Velocity = @vel_eci.y;

// --- Default type parameters ---
// Unframed marker type
pub type Unframed {}

// Generic struct with default type param: F defaults to Unframed
pub type Pos3<D: Dim, F: Type = Unframed> {
    x: D,
    y: D,
    z: D,
}

// Use with all args explicitly
param pos3_eci: Pos3<Length, Eci> = Pos3<Length, Eci> { x: 100.0 km, y: 200.0 km, z: 300.0 km};

// Use with default (omit F, gets Unframed)
param pos3_default: Pos3<Length> = Pos3<Length> { x: 10.0 km, y: 20.0 km, z: 30.0 km};

node pos3_eci_x: Length = @pos3_eci.x;
node pos3_default_y: Length = @pos3_default.y;

// --- as cast (phantom type parameter change) ---
// Cast a Vec3 from Eci frame to Body frame (phantom param only)
node pos_body: Vec3<Length, Body> = @pos_eci as Vec3<Length, Body>;
node pos_body_x: Length = @pos_body.x;

// Non-generic struct still works alongside generics
pub type TransferResult {
    dv1: Velocity,
    dv2: Velocity,
}

node transfer: TransferResult = TransferResult { dv1: 100.0 m/s, dv2: 200.0 m/s};
node total_dv: Velocity = @transfer.dv1 + @transfer.dv2;
