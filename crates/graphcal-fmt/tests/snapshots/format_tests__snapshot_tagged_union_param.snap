// tagged_union_param.gcl -- Tagged union as a param (for JSON input testing)
dim Velocity = Length / Time;
dim Force = Mass * Length / Time^2;

type Impulsive {
    delta_v: Velocity,
}
type LowThrust {
    thrust: Force,
    duration: Time,
}
type ManeuverKind = Impulsive | LowThrust;

param maneuver: ManeuverKind = LowThrust { thrust: 0.5 N, duration: 3600.0 s};

node fuel_proxy: Force = match @maneuver {
    Impulsive { delta_v: _ } => 0.0 N,
    LowThrust { thrust, duration: _ } => thrust,
};
