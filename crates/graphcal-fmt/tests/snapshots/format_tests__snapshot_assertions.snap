---
source: crates/graphcal-fmt/tests/format_tests.rs
expression: formatted
---
// assertions.gcl -- Assertion feature tests
dim Velocity = Length / Time;
dim Force = Mass * Length / Time^2;

param mass: Mass = 100.0 kg;
param velocity: Velocity = 50.0 m/s;
param max_velocity: Velocity = 200.0 m/s;

node momentum: Force * Time = @mass * @velocity;

// Boolean assertion (should pass)
assert velocity_in_range = @velocity < @max_velocity;

// Tolerance assertion (absolute, should pass)
assert mass_approx = @mass ~= 100.1 kg +/- 1.0 kg;

// Tolerance assertion (relative, should pass)
assert velocity_approx = @velocity ~= 49.5 m/s +/- 5%;
