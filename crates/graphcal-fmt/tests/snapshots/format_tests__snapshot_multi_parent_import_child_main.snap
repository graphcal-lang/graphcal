// child/main.gcl -- Attempts to import from parent directory using "../"
//
// This is expected to FAIL because the project root is the entry-point
// file's directory (child/). The import "../lib.gcl" resolves outside
// this boundary and is rejected by the path sandboxing check.
import "../lib.gcl" { base_value, SCALE };

node result: Dimensionless = @base_value * SCALE;
